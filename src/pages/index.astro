---
import MainLayout from '../layouts/MainLayout.astro';

// Common Components
import Navbar from '../components/common/Navbar.astro';
import Footer from '../components/common/Footer.astro';
import WhatsAppButton from '../components/common/WhatsAppButton.astro';

// Section Components
import Hero from '../components/sections/Hero.astro';
import Portfolio from '../components/sections/Portfolio.astro';
import WhyUs from '../components/sections/WhyUs.astro';
import AlurPengerjaan from '../components/sections/AlurPengerjaan.astro';
import Harga from '../components/sections/Harga.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import CTA from '../components/sections/CTA.astro';

// Modal Components
import ExitPopup from '../components/modals/ExitPopup.astro';

// Utils & Constants
import { WHATSAPP_LINK, PAGE_TITLE } from '../utils/constants';

const whatsappLink = WHATSAPP_LINK;
---

<MainLayout title={PAGE_TITLE}>
  <Navbar whatsappLink={whatsappLink} />
  
  <main>
    <Hero whatsappLink={whatsappLink} />
    <Portfolio />
    <WhyUs />
    <AlurPengerjaan />
    <Harga whatsappLink={whatsappLink} />
    <Testimonials />
    <CTA whatsappLink={whatsappLink} />
  </main>

  <Footer />

  <!-- Floating UI Elements -->
  <WhatsAppButton whatsappLink={whatsappLink} />
  <ExitPopup whatsappLink={whatsappLink} />
</MainLayout>
