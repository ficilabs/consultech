---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import PainPoints from '../components/PainPoints.astro';
import Stats from '../components/Stats.astro';
import Features from '../components/Features.astro';
import Expertise from '../components/Expertise.astro';
import Portfolio from '../components/Portfolio.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import ExitPopup from '../components/ExitPopup.astro';

const whatsappLink = "https://wa.me/6281234567890?text=Halo%20Konsultech,%20saya%20mau%20konsultasi";
---

<MainLayout title="Konsultech - Solusi Project & Skripsi Anak Teknik">
  <Navbar whatsappLink={whatsappLink} />
  
  <main>
    <Hero whatsappLink={whatsappLink} />
    <PainPoints whatsappLink={whatsappLink} />
    <Stats />
    <Features />
    <Expertise />
    <Portfolio />
    <Testimonials />
    <CTA whatsappLink={whatsappLink} />
  </main>

  <Footer />

  <!-- Floating UI Elements -->
  <WhatsAppButton whatsappLink={whatsappLink} />
  <ExitPopup whatsappLink={whatsappLink} />
</MainLayout>
