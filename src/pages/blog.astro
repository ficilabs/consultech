---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/common/Navbar.astro';
import Footer from '../components/common/Footer.astro';
import WhatsAppButton from '../components/common/WhatsAppButton.astro';
import ExitPopup from '../components/modals/ExitPopup.astro';
import ProjectBlog from '../components/sections/ProjectBlog.astro';
import { blogPosts } from '../data/blog';
import { PAGE_TITLE, WHATSAPP_LINK } from '../utils/constants';

const whatsappLink = WHATSAPP_LINK;
const title = `${PAGE_TITLE} — Blog Proyek`;
const description = 'Cerita proyek lengkap beserta desain, kode, dan alur kerja untuk setiap solusi IoT.';
const post = blogPosts[0];
---

<MainLayout title={title} description={description}>
  <Navbar whatsappLink={whatsappLink} />

  <main>
    <ProjectBlog post={post} />
  </main>

  <Footer />
  <WhatsAppButton whatsappLink={whatsappLink} />
  <ExitPopup whatsappLink={whatsappLink} />
</MainLayout>
