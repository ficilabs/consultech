---
---
<section id="layanan" class="py-24 bg-white relative overflow-hidden">
    <!-- subtle bg decoration -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-orange-50 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl opacity-60 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-72 h-72 bg-amber-50 rounded-full translate-y-1/2 -translate-x-1/2 blur-3xl opacity-60 pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <!-- Header -->
        <div class="text-center mb-16">
            <span class="inline-block px-4 py-1.5 rounded-full bg-orange-100 text-orange-600 font-bold text-sm uppercase tracking-widest mb-4">Keahlian Kami</span>
            <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4">Semua Yang Kamu Butuhkan, <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-amber-400">Ada di Sini</span></h2>
            <p class="text-slate-500 max-w-xl mx-auto">Dari hardware sampai data, dari 3D sampai backend — kami siap dampingi projectmu.</p>
        </div>

        <!-- Card Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">

            <!-- 1. Arduino & IoT -->
            <div class="group relative bg-white rounded-3xl p-8 border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-orange-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-3xl"></div>
                <div class="relative z-10">
                    <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-orange-400 to-amber-400 flex items-center justify-center text-2xl shadow-lg shadow-orange-200 mb-5">🔌</div>
                    <h3 class="text-xl font-bold text-slate-900 mb-2">Arduino & IoT</h3>
                    <p class="text-slate-500 text-sm leading-relaxed mb-4">Sensor, aktuator, komunikasi data, dan integrasi cloud untuk sistem embedded.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="px-3 py-1 bg-orange-50 text-orange-600 text-xs font-semibold rounded-full border border-orange-100">ESP32</span>
                        <span class="px-3 py-1 bg-orange-50 text-orange-600 text-xs font-semibold rounded-full border border-orange-100">MQTT</span>
                        <span class="px-3 py-1 bg-orange-50 text-orange-600 text-xs font-semibold rounded-full border border-orange-100">Firebase</span>
                    </div>
                </div>
            </div>

            <!-- 2. Machine Learning -->
            <div class="group relative bg-white rounded-3xl p-8 border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-blue-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-3xl"></div>
                <div class="relative z-10">
                    <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-500 flex items-center justify-center text-2xl shadow-lg shadow-blue-200 mb-5">🤖</div>
                    <h3 class="text-xl font-bold text-slate-900 mb-2">Machine Learning</h3>
                    <p class="text-slate-500 text-sm leading-relaxed mb-4">Klasifikasi, deteksi objek, NLP, dan deploy model untuk skripsi atau project nyata.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="px-3 py-1 bg-blue-50 text-blue-600 text-xs font-semibold rounded-full border border-blue-100">Python</span>
                        <span class="px-3 py-1 bg-blue-50 text-blue-600 text-xs font-semibold rounded-full border border-blue-100">TensorFlow</span>
                        <span class="px-3 py-1 bg-blue-50 text-blue-600 text-xs font-semibold rounded-full border border-blue-100">CNN/YOLO</span>
                    </div>
                </div>
            </div>

            <!-- 3. Web & Mobile -->
            <div class="group relative bg-white rounded-3xl p-8 border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-purple-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-3xl"></div>
                <div class="relative z-10">
                    <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center text-2xl shadow-lg shadow-purple-200 mb-5">💻</div>
                    <h3 class="text-xl font-bold text-slate-900 mb-2">Web & Mobile</h3>
                    <p class="text-slate-500 text-sm leading-relaxed mb-4">Full-stack development mulai dari UI/UX, REST API, hingga deploy ke production.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="px-3 py-1 bg-purple-50 text-purple-600 text-xs font-semibold rounded-full border border-purple-100">Laravel</span>
                        <span class="px-3 py-1 bg-purple-50 text-purple-600 text-xs font-semibold rounded-full border border-purple-100">React</span>
                        <span class="px-3 py-1 bg-purple-50 text-purple-600 text-xs font-semibold rounded-full border border-purple-100">Flutter</span>
                    </div>
                </div>
            </div>

            <!-- 4. Data Analyst -->
            <div class="group relative bg-white rounded-3xl p-8 border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-teal-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-3xl"></div>
                <div class="relative z-10">
                    <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-teal-400 to-cyan-500 flex items-center justify-center text-2xl shadow-lg shadow-teal-200 mb-5">📊</div>
                    <h3 class="text-xl font-bold text-slate-900 mb-2">Data Analyst</h3>
                    <p class="text-slate-500 text-sm leading-relaxed mb-4">Pengolahan data, visualisasi, dan insight analitik untuk skripsi berbasis data.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="px-3 py-1 bg-teal-50 text-teal-600 text-xs font-semibold rounded-full border border-teal-100">Pandas</span>
                        <span class="px-3 py-1 bg-teal-50 text-teal-600 text-xs font-semibold rounded-full border border-teal-100">Tableau</span>
                        <span class="px-3 py-1 bg-teal-50 text-teal-600 text-xs font-semibold rounded-full border border-teal-100">Power BI</span>
                    </div>
                </div>
            </div>

            <!-- 5. Blender 3D -->
            <div class="group relative bg-white rounded-3xl p-8 border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-rose-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-3xl"></div>
                <div class="relative z-10">
                    <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-rose-400 to-orange-400 flex items-center justify-center text-2xl shadow-lg shadow-rose-200 mb-5">🎨</div>
                    <h3 class="text-xl font-bold text-slate-900 mb-2">Blender 3D</h3>
                    <p class="text-slate-500 text-sm leading-relaxed mb-4">Modeling, rendering, animasi, dan simulasi 3D untuk project multimedia dan tugas akhir.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="px-3 py-1 bg-rose-50 text-rose-600 text-xs font-semibold rounded-full border border-rose-100">Modeling</span>
                        <span class="px-3 py-1 bg-rose-50 text-rose-600 text-xs font-semibold rounded-full border border-rose-100">Rendering</span>
                        <span class="px-3 py-1 bg-rose-50 text-rose-600 text-xs font-semibold rounded-full border border-rose-100">Animation</span>
                    </div>
                </div>
            </div>

            <!-- 6. Laporan & Skripsi -->
            <div class="group relative bg-white rounded-3xl p-8 border border-slate-100 shadow-sm hover:shadow-xl hover:-translate-y-1.5 transition-all duration-300 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-green-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-3xl"></div>
                <div class="relative z-10">
                    <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-green-400 to-emerald-500 flex items-center justify-center text-2xl shadow-lg shadow-green-200 mb-5">📝</div>
                    <h3 class="text-xl font-bold text-slate-900 mb-2">Laporan & Skripsi</h3>
                    <p class="text-slate-500 text-sm leading-relaxed mb-4">Bimbingan penulisan, kerangka bab, metodologi, hingga persiapan sidang akhir.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="px-3 py-1 bg-green-50 text-green-600 text-xs font-semibold rounded-full border border-green-100">Metodologi</span>
                        <span class="px-3 py-1 bg-green-50 text-green-600 text-xs font-semibold rounded-full border border-green-100">Analisis</span>
                        <span class="px-3 py-1 bg-green-50 text-green-600 text-xs font-semibold rounded-full border border-green-100">Sidang</span>
                    </div>
                </div>
            </div>

        </div><!-- end grid -->
    </div>
</section>
