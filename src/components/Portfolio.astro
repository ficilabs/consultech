---
---
<section id="portofolio" class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Project yang Pernah Dibuat</h2>
            <p class="text-slate-500">Intip hasil mentoring bareng Kampus IoT.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Project 1 -->
            <div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all hover:-translate-y-1 border border-slate-100 flex flex-col">
                <img src="https://placehold.co/600x400/e0f2fe/0284c7?text=Smart+Traffic+Light" alt="Smart Traffic Light" class="w-full aspect-video object-cover" />
                <div class="p-6 flex-1 flex flex-col">
                    <h3 class="font-bold text-xl text-slate-900 mb-2">Smart Traffic Light</h3>
                    <p class="text-slate-600 text-sm mb-4">Sistem lampu lalu lintas pintar berbasis logika fuzzy dan prioritas RFID.</p>
                    <div class="mt-auto">
                        <p class="text-orange-500 text-sm font-bold bg-orange-50 inline-block px-3 py-1 rounded-md">ESP32 • Fuzzy Logic • RFID</p>
                    </div>
                </div>
            </div>
            
            <!-- Project 2 -->
            <div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all hover:-translate-y-1 border border-slate-100 flex flex-col">
                <img src="https://placehold.co/600x400/dcfce7/16a34a?text=Smart+Greenhouse" alt="Smart Greenhouse" class="w-full aspect-video object-cover" />
                <div class="p-6 flex-1 flex flex-col">
                    <h3 class="font-bold text-xl text-slate-900 mb-2">Smart Greenhouse</h3>
                    <p class="text-slate-600 text-sm mb-4">Monitoring suhu dan kelembaban otomatis untuk tanaman hidroponik.</p>
                    <div class="mt-auto">
                        <p class="text-orange-500 text-sm font-bold bg-orange-50 inline-block px-3 py-1 rounded-md">NodeMCU • Sensor • IoT</p>
                    </div>
                </div>
            </div>

            <!-- Project 3 -->
            <div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all hover:-translate-y-1 border border-slate-100 flex flex-col">
                <img src="https://placehold.co/600x400/f3e8ff/9333ea?text=MQTT+Monitoring" alt="MQTT Monitoring System" class="w-full aspect-video object-cover" />
                <div class="p-6 flex-1 flex flex-col">
                    <h3 class="font-bold text-xl text-slate-900 mb-2">MQTT Monitoring System</h3>
                    <p class="text-slate-600 text-sm mb-4">Sistem pemantauan data sensor real-time menggunakan protokol komunikasi MQTT.</p>
                    <div class="mt-auto">
                        <p class="text-orange-500 text-sm font-bold bg-orange-50 inline-block px-3 py-1 rounded-md">Raspberry Pi • MQTT • Node-RED</p>
                    </div>
                </div>
            </div>

            <!-- Project 4 -->
            <div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all hover:-translate-y-1 border border-slate-100 flex flex-col">
                <img src="https://placehold.co/600x400/fff7ed/ea580c?text=RFID+Attendance" alt="RFID Attendance System" class="w-full aspect-video object-cover" />
                <div class="p-6 flex-1 flex flex-col">
                    <h3 class="font-bold text-xl text-slate-900 mb-2">RFID Attendance System</h3>
                    <p class="text-slate-600 text-sm mb-4">Sistem absensi otomatis terintegrasi dengan database dan dashboard web.</p>
                    <div class="mt-auto">
                        <p class="text-orange-500 text-sm font-bold bg-orange-50 inline-block px-3 py-1 rounded-md">ESP8266 • RFID • MySQL</p>
                    </div>
                </div>
            </div>

            <!-- Project 5 -->
            <div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all hover:-translate-y-1 border border-slate-100 flex flex-col">
                <img src="https://placehold.co/600x400/f1f5f9/475569?text=IoT+Dashboard" alt="IoT Dashboard" class="w-full aspect-video object-cover" />
                <div class="p-6 flex-1 flex flex-col">
                    <h3 class="font-bold text-xl text-slate-900 mb-2">IoT Dashboard Web</h3>
                    <p class="text-slate-600 text-sm mb-4">Dashboard interaktif untuk mengontrol relay dan visualisasi data chart.</p>
                    <div class="mt-auto">
                        <p class="text-orange-500 text-sm font-bold bg-orange-50 inline-block px-3 py-1 rounded-md">React • Firebase • API</p>
                    </div>
                </div>
            </div>

            <!-- Project 6 -->
            <div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all hover:-translate-y-1 border border-slate-100 flex flex-col">
                <img src="https://placehold.co/600x400/fdf4ff/c026d3?text=Air+Quality" alt="Air Quality Monitoring" class="w-full aspect-video object-cover" />
                <div class="p-6 flex-1 flex flex-col">
                    <h3 class="font-bold text-xl text-slate-900 mb-2">Air Quality Monitoring</h3>
                    <p class="text-slate-600 text-sm mb-4">Pendeteksi polusi udara dan kualitas lingkungan sekitar berbasis IoT.</p>
                    <div class="mt-auto">
                        <p class="text-orange-500 text-sm font-bold bg-orange-50 inline-block px-3 py-1 rounded-md">ESP32 • MQ135 • Thingspeak</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
