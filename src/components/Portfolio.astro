---
---
<section id="portofolio" class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Project yang Pernah Dibuat</h2>
            <p class="text-slate-500">Intip hasil mentoring bareng Konsultech.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Project 1 -->
            <div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all hover:-translate-y-1 border border-slate-100">
                <img src="https://placehold.co/600x400/e0f2fe/0284c7?text=Smart+Home+Dashboard" alt="IoT Project" class="w-full aspect-video object-cover" />
                <div class="p-6">
                    <h3 class="font-bold text-xl text-slate-900">Sistem IoT Smart Home</h3>
                    <p class="text-orange-500 text-sm font-bold mt-2 bg-orange-50 inline-block px-3 py-1 rounded-md">ESP32 • Firebase • React</p>
                </div>
            </div>
            
            <!-- Project 2 -->
            <div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all hover:-translate-y-1 border border-slate-100">
                <img src="https://placehold.co/600x400/dcfce7/16a34a?text=Deteksi+Hama" alt="ML Project" class="w-full aspect-video object-cover" />
                <div class="p-6">
                    <h3 class="font-bold text-xl text-slate-900">Klasifikasi Hama Tanaman</h3>
                    <p class="text-orange-500 text-sm font-bold mt-2 bg-orange-50 inline-block px-3 py-1 rounded-md">Python • TensorFlow • CNN</p>
                </div>
            </div>

            <!-- Project 3 -->
            <div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all hover:-translate-y-1 border border-slate-100">
                <img src="https://placehold.co/600x400/f3e8ff/9333ea?text=Sistem+Kasir" alt="Web Project" class="w-full aspect-video object-cover" />
                <div class="p-6">
                    <h3 class="font-bold text-xl text-slate-900">Aplikasi Kasir (POS)</h3>
                    <p class="text-orange-500 text-sm font-bold mt-2 bg-orange-50 inline-block px-3 py-1 rounded-md">Laravel • Tailwind • MySQL</p>
                </div>
            </div>
        </div>
    </div>
</section>
