<section id="testimoni" class="py-24 bg-orange-50 relative">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-orange-200 to-transparent"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-16">Kata Mereka yang Udah Lulus</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Testi 1 -->
            <div class="bg-white p-8 rounded-3xl shadow-sm text-left relative group hover:shadow-xl transition-all duration-300">
                <div class="flex text-orange-400 mb-4">
                    {[1, 2, 3, 4, 5].map(() => (
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                    ))}
                </div>
                <p class="text-slate-600 mb-6 italic leading-relaxed">"Awalnya stuck total sama error di project Laravel. Untung ketemu Konsultech, diajarin logikanya sampai akhirnya bisa sidang tepat waktu!"</p>
                <div class="flex items-center gap-4">
                    <img src="https://placehold.co/100x100/e2e8f0/475569?text=DA" alt="User" class="w-12 h-12 rounded-full border-2 border-orange-100" />
                    <div>
                        <h4 class="font-bold text-slate-900">Dimas A.</h4>
                        <p class="text-sm text-slate-500">Teknik Informatika '19</p>
                    </div>
                </div>
            </div>

