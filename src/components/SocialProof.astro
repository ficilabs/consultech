<div id="social-proof" class="fixed bottom-24 left-6 z-[9998] bg-white rounded-2xl p-4 shadow-[0_8px_40px_rgba(0,0,0,0.1)] flex items-center gap-4 max-w-[300px] border border-slate-100 transition-all duration-500 translate-x-[-150%]">
    <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center text-orange-500 font-bold text-lg">
        👤
    </div>
    <div>
        <p id="notif-text" class="font-bold text-sm text-slate-900 leading-tight">Bagas dari Surabaya</p>
        <p class="text-xs text-slate-500 mt-0.5">baru saja memulai konsultasi 🎉</p>
    </div>
</div>

<script>
    const names = ['Bagas (Surabaya)','Rania (Jakarta)','Kevin (Bandung)','Siti (Yogyakarta)','Andre (Malang)','Putri (Semarang)','Dito (Medan)','Ayu (Makassar)'];
    const proof = document.getElementById('social-proof');
    const notifText = document.getElementById('notif-text');
    let ni = 0;

    function showNotif() {
        if (!proof || !notifText) return;
        notifText.textContent = names[ni % names.length];
        proof.classList.remove('translate-x-[-150%]');
        proof.classList.add('translate-x-0');
        ni++;
        setTimeout(() => {
            proof.classList.remove('translate-x-0');
            proof.classList.add('translate-x-[-150%]');
        }, 4000);
    }

    if (proof) {
        setTimeout(() => {
            showNotif();
            setInterval(showNotif, 15000);
        }, 5000);
    }
</script>
