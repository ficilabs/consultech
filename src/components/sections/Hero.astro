---
const { whatsappLink } = Astro.props;
---
<section class="relative pt-24 pb-16 lg:pt-0 lg:pb-0 lg:min-h-screen lg:flex lg:items-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0 -z-20">
        <img 
            src="/landingpage.png" 
            alt="Pembelajaran IoT profesional dengan mentoring langsung" 
            class="w-full h-full object-cover"
        />
    </div>

    <!-- Overlay gradient supaya teks tetap kebaca -->
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-slate-900/90 via-slate-900/70 to-slate-900/30"></div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-slate-900/80 via-transparent to-slate-900/20 lg:hidden"></div>

    <!-- Animated background gradients (tetap dipertahankan, lebih halus di atas overlay) -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
        <div class="absolute top-0 left-0 w-96 h-96 bg-orange-500 rounded-full mix-blend-soft-light filter blur-3xl opacity-20 animate-blob"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-amber-400 rounded-full mix-blend-soft-light filter blur-3xl opacity-20 animate-blob animation-delay-2000"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 w-full py-12 lg:py-0">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
            <!-- Left Content -->
            <div class="space-y-6 lg:space-y-8">
                <!-- Main Heading -->
                <div class="space-y-3">
                    <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight tracking-tight drop-shadow-md">
                        Kesulitan Mengerjakan <br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-400 to-amber-300">Proyek IoT?</span>
                    </h1>
                    <p class="text-base md:text-lg text-slate-200 leading-relaxed max-w-xl">
                        Dapatkan pendampingan IoT lengkap untuk skripsi dan proyek tanpa repot.
                    </p>
                </div>

                <!-- CTA Buttons -->
                <div class="flex flex-col sm:flex-row gap-4 pt-4">
                    <a href={whatsappLink} class="group relative px-7 py-4 bg-gradient-to-r from-orange-500 to-orange-600 text-white font-bold text-base rounded-full shadow-lg shadow-orange-500/30 hover:shadow-orange-500/50 transition-all duration-300 hover:-translate-y-1 text-center overflow-hidden">
                        Konsultasi via WhatsApp
                    </a>
                    <a href="#portfolio" class="px-7 py-4 bg-white/10 backdrop-blur-sm border-2 border-white/30 text-white font-bold text-base rounded-full hover:border-orange-400 hover:text-orange-300 transition-all duration-300 hover:-translate-y-1 text-center">
                        Lihat Portofolio
                    </a>
                </div>
            </div>

            <!-- Right column dikosongkan / bisa diisi elemen lain karena gambar sudah jadi background -->
            <div class="hidden lg:block"></div>
        </div>
    </div>
</section>

<style>
    @keyframes blob {
        0%, 100% {
            transform: translate(0, 0) scale(1);
        }
        33% {
            transform: translate(30px, -50px) scale(1.1);
        }
        66% {
            transform: translate(-20px, 20px) scale(0.9);
        }
    }

    .animate-blob {
        animation: blob 7s infinite;
    }

    .animation-delay-2000 {
        animation-delay: 2s;
    }
</style>