---
<section id="alur-pengerjaan" class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Proses Pemesanan Mudah</h2>
            <p class="text-slate-500">5 langkah sederhana untuk memulai project IoT Anda.</p>
        </div>

        <div class="relative max-w-4xl mx-auto">
            <!-- Timeline Line -->
            <div class="hidden md:block absolute top-1/2 left-0 w-full h-1 bg-slate-200 -translate-y-1/2 z-0"></div>
            
            <div class="grid grid-cols-1 md:grid-cols-5 gap-8 relative z-10">
                
                <!-- Step 1 -->
                <div class="text-center group">
                    <div class="w-16 h-16 mx-auto bg-white border-4 border-slate-100 group-hover:border-orange-500 rounded-full flex items-center justify-center text-xl font-bold text-slate-400 group-hover:text-orange-500 transition-colors shadow-sm mb-4">
                        1
                    </div>
                    <h3 class="font-bold text-slate-900 mb-2">Konsultasi</h3>
                    <p class="text-sm text-slate-500">Ceritakan ide dan kebutuhan sistem Anda.</p>
                </div>

                <!-- Step 2 -->
                <div class="text-center group">
                    <div class="w-16 h-16 mx-auto bg-white border-4 border-slate-100 group-hover:border-orange-500 rounded-full flex items-center justify-center text-xl font-bold text-slate-400 group-hover:text-orange-500 transition-colors shadow-sm mb-4">
                        2
                    </div>
                    <h3 class="font-bold text-slate-900 mb-2">Pilih Paket</h3>
                    <p class="text-sm text-slate-500">Pilih paket layanan sesuai budget Anda.</p>
                </div>

                <!-- Step 3 -->
                <div class="text-center group">
                    <div class="w-16 h-16 mx-auto bg-white border-4 border-slate-100 group-hover:border-orange-500 rounded-full flex items-center justify-center text-xl font-bold text-slate-400 group-hover:text-orange-500 transition-colors shadow-sm mb-4">
                        3
                    </div>
                    <h3 class="font-bold text-slate-900 mb-2">Pengerjaan</h3>
                    <p class="text-sm text-slate-500">Proses coding dan perakitan hardware.</p>
                </div>

                <!-- Step 4 -->
                <div class="text-center group">
                    <div class="w-16 h-16 mx-auto bg-white border-4 border-slate-100 group-hover:border-orange-500 rounded-full flex items-center justify-center text-xl font-bold text-slate-400 group-hover:text-orange-500 transition-colors shadow-sm mb-4">
                        4
                    </div>
                    <h3 class="font-bold text-slate-900 mb-2">Pengiriman</h3>
                    <p class="text-sm text-slate-500">Pengiriman alat yang sudah siap pakai.</p>
                </div>

                <!-- Step 5 -->
                <div class="text-center group">
                    <div class="w-16 h-16 mx-auto bg-white border-4 border-slate-100 group-hover:border-orange-500 rounded-full flex items-center justify-center text-xl font-bold text-slate-400 group-hover:text-orange-500 transition-colors shadow-sm mb-4">
                        5
                    </div>
                    <h3 class="font-bold text-slate-900 mb-2">Support</h3>
                    <p class="text-sm text-slate-500">Pendampingan pasca pengiriman alat.</p>
                </div>

            </div>
        </div>
    </div>
</section>
